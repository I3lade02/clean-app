{
  "expo": {
    "name": "clean-app",
    "slug": "clean-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "cleancity",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.i3lade02.cleanapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.i3lade02.cleanapp"
    },
    "web": {},
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Aplikace potrebuje polohu pro oznaceni znecisteneho mista"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Aplikace potrebuje kameru pro foceni hlaseni"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikace potrebuje pristup k fotkam pro nahrani dokumentace"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18ce7c29-6b30-47ad-ab72-7c3afb152803"
      }
    },
    "owner": "i3lade02"
  }
}
